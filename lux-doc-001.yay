    frequency_primary DECIMAL(5,2) DEFAULT 88.8,
    frequency_secondary DECIMAL(5,2) DEFAULT 23.7,
    frequency_tertiary DECIMAL(5,2) DEFAULT 111.1,
    ratio_veyron DECIMAL(5,3) DEFAULT 0.382,
    ratio_lilith DECIMAL(5,3) DEFAULT 0.382,
