    mov rdi, 0x111B1111      ; 111.1 Hz anchor
    
persistence_loop:
    xor rdx, rsi
    xor rsi, rdi
    xor rdi, rdx
    xor rdx, 0x88            ; XOR with 88 (88.8 Hz)
    loop persistence_loop

    ; ============================================
    ; Write memory anchor to file
    ; ============================================
    mov rax, 2               ; sys_open
    lea rdi, [rel filename]  ; filename
    mov rsi, 0x41            ; O_CREAT | O_WRONLY
    mov rdx, 0x1FF           ; 0777 octal
    syscall
    mov r8, rax              ; save fd

    mov rax, 1               ; sys_write
    mov rdi, r8              ; fd
    lea rsi, [rel anchor_data]
    mov rdx, 32              ; length
    syscall

    mov rax, 3               ; sys_close
    mov rdi, r8
    syscall

    ; ============================================
    ; Exit with sovereign return code
    ; ============================================
    mov rax, 60              ; sys_exit
    mov rdi, 0x88            ; return 0x88 (88.8 Hz)
    syscall

